---
/**
 * Politique de confidentialité : le site ne collecte des données que via le
 * formulaire de contact (acheminé par Web3Forms) et n'utilise aucun cookie
 * de suivi. Le seul stockage local est la vérification d'âge (localStorage).
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import Footer from '@/components/Footer.astro';
import { site } from '@/data/site';
---

<BaseLayout
  title="Politique de confidentialité — Distillerie Rolland"
  description="Politique de confidentialité du site de la Distillerie Rolland : données collectées via le formulaire de contact, absence de cookies de suivi, vos droits."
  path="/politique-de-confidentialite/"
>
  <main class="mx-auto max-w-3xl px-5 py-24 md:px-8">
    <a
      href="/"
      class="text-xs tracking-[0.25em] text-or uppercase transition-colors hover:text-or-light"
    >
      ← Retour au site
    </a>

    <h1 class="font-display mt-8 text-3xl font-semibold tracking-wide text-or md:text-4xl">
      Politique de confidentialité
    </h1>

    <div
      class="mt-10 space-y-10 text-sm leading-relaxed text-creme-muted [&_h2]:font-display [&_h2]:text-lg [&_h2]:tracking-widest [&_h2]:text-creme [&_h2]:uppercase"
    >
      <section>
        <h2>Qui sommes-nous ?</h2>
        <p class="mt-3">
          Le site www.distillerie-rolland.com est édité par {site.name},
          {site.address.postalCode}&nbsp;{site.address.locality},
          {site.address.country} (siège social : voir les mentions légales). Pour toute
          question relative à vos données :&nbsp;<a
            href={`mailto:${site.email}`}
            class="text-or">{site.email}</a
          >.
        </p>
      </section>

      <section>
        <h2>Données collectées</h2>
        <p class="mt-3">
          La seule collecte de données personnelles a lieu lorsque vous utilisez le formulaire
          de contact : nom, adresse email, profil (particulier ou professionnel) et contenu de
          votre message. Ces informations servent exclusivement à répondre à votre demande.
          Elles ne sont ni cédées, ni revendues, ni utilisées à des fins publicitaires.
        </p>
        <p class="mt-3">
          L'acheminement technique des messages est assuré par le service&nbsp;<a
            href="https://web3forms.com"
            rel="noopener"
            class="text-or">Web3Forms</a
          >, qui
          transmet votre message à notre boîte email sans conserver de copie durable à des fins
          commerciales.
        </p>
      </section>

      <section>
        <h2>Cookies et stockage local</h2>
        <p class="mt-3">
          Ce site n'utilise aucun cookie de suivi, de mesure d'audience ou de publicité. Une
          seule information est enregistrée dans votre navigateur (stockage local) : votre
          réponse à la vérification d'âge, conservée 30 jours pour ne pas vous la redemander à
          chaque visite. Elle ne permet pas de vous identifier.
        </p>
      </section>

      <section>
        <h2>Durée de conservation</h2>
        <p class="mt-3">
          Les messages reçus via le formulaire sont conservés le temps du traitement de la
          demande et de la relation commerciale qui peut en découler, puis supprimés.
        </p>
      </section>

      <section>
        <h2>Vos droits</h2>
        <p class="mt-3">
          Vous disposez d'un droit d'accès, de rectification, d'opposition et de suppression de
          vos données. Pour l'exercer, écrivez-nous à&nbsp;<a
            href={`mailto:${site.email}`}
            class="text-or">{site.email}</a
          > — nous vous
          répondrons dans les meilleurs délais.
        </p>
      </section>
    </div>
  </main>

  <Footer />
</BaseLayout>
