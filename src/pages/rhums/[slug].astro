---
/**
 * Pages produit (/rhums/<slug>/) — une par création disponible.
 * Ton strictement informatif (méthode, composition, origine) : la loi Évin
 * autorise l'information factuelle, pas l'incitation — pas de prix, pas
 * d'achat, pas de mise en scène de consommation.
 * SEO : Schema.org Product (sans offre) + fil d'Ariane + page indexable.
 */
import { Image } from 'astro:assets';
import BaseLayout from '@/layouts/BaseLayout.astro';
import AgeGate from '@/components/AgeGate.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { site, products } from '@/data/site';

import blancCiel from '@/assets/images/rhum-blanc-la-metisse-bouteille-ciel-caledonien.jpg';
import blancVallee from '@/assets/images/rhum-blanc-la-metisse-vallee-moindou.jpg';
import blancCoucher from '@/assets/images/rhum-blanc-la-metisse-coucher-de-soleil.jpg';
import blancPaysage from '@/assets/images/rhum-blanc-la-metisse-paysage-caledonien.jpg';
import cireBleue from '@/assets/images/cire-bleue-cachetage-la-metisse.jpg';
import brunContreJour from '@/assets/images/rhum-brun-gaiac-bouteilles-contre-jour-acajou.jpg';
import brunMiseEnBouteille from '@/assets/images/rhum-brun-gaiac-mise-en-bouteille-moindou.jpg';
import brunRobeDoree from '@/assets/images/rhum-brun-gaiac-robe-doree-soleil.jpg';
import brunRangees from '@/assets/images/rhum-brun-gaiac-rangees-bouteilles-acajou.jpg';

export function getStaticPaths() {
  return products
    .filter((p) => p.available && p.slug)
    .map((p) => ({ params: { slug: p.slug }, props: { product: p } }));
}

const { product } = Astro.props;
const path = `/rhums/${product.slug}/`;

// Visuels par produit : bannière hero + galerie complémentaire + vidéos
const medias = {
  'la-metisse-rhum-blanc': {
    hero: {
      src: blancPaysage,
      alt: 'La Métisse rhum blanc devant les collines calédoniennes au soleil couchant',
      position: 'object-[center_60%]',
    },
    galerie: [
      { src: blancCiel, alt: 'Bouteille de rhum blanc La Métisse sous le ciel bleu de Nouvelle-Calédonie' },
      { src: blancVallee, alt: 'Rhum blanc La Métisse dans la vallée de Moindou' },
      { src: blancCoucher, alt: 'Rhum blanc La Métisse au coucher de soleil, Nouvelle-Calédonie' },
    ],
    videos: [
      {
        src: '/videos/rhum-blanc-la-metisse-presentation.mp4',
        poster: blancCiel.src,
        caption: 'La Métisse, rhum blanc traditionnel',
        aria: 'Présentation de la bouteille de rhum blanc La Métisse',
      },
      {
        src: '/videos/cachetage-cire-bleue-la-metisse.mp4',
        poster: cireBleue.src,
        caption: 'Le cachetage à la cire, bouteille par bouteille',
        aria: "Cachetage à la main d'une bouteille La Métisse dans la cire",
      },
    ],
  },
  'la-metisse-rhum-brun-gaiac': {
    hero: {
      src: brunContreJour,
      alt: 'Bouteilles de rhum brun au cœur de gaïac torréfié à contre-jour, robe rouge acajou',
      position: 'object-[center_45%]',
    },
    galerie: [
      { src: brunRangees, alt: 'Rangées de bouteilles de rhum brun au gaïac, reflets rouge acajou au soleil — Distillerie Rolland' },
      { src: brunMiseEnBouteille, alt: 'Mise en bouteille du rhum brun au cœur de gaïac torréfié à Moindou' },
      { src: brunRobeDoree, alt: 'Robe dorée aux reflets rouge acajou du rhum brun au gaïac dans la lumière' },
    ],
    videos: [
      {
        src: '/videos/remplissage-rhum-brun-gaiac.mp4',
        poster: brunRangees.src,
        caption: 'Le remplissage, bouteille par bouteille',
        aria: "Remplissage d'une bouteille de rhum brun au cœur de gaïac torréfié",
      },
    ],
  },
  'rhums-arranges': { hero: null, galerie: [], videos: [] },
} as const;
const media = medias[product.slug as keyof typeof medias] ?? { hero: null, galerie: [], videos: [] };

const title = `${product.name} — Distillerie Rolland, Nouvelle-Calédonie`;

const imagesLd = [
  ...(media.hero ? [media.hero.src] : []),
  ...media.galerie.map((g) => g.src),
].map((img) => new URL(img.src, site.domain).href);

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Product',
      name: product.name,
      description: product.description,
      brand: { '@type': 'Brand', name: 'La Métisse' },
      manufacturer: { '@id': `${site.domain}/#distillerie` },
      countryOfOrigin: 'NC',
      ...(imagesLd.length > 0 && { image: imagesLd }),
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Accueil', item: `${site.domain}/` },
        { '@type': 'ListItem', position: 2, name: 'Nos rhums', item: `${site.domain}/rhums/` },
        { '@type': 'ListItem', position: 3, name: product.name },
      ],
    },
  ],
};
---

<BaseLayout title={title} description={product.description} path={path}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" />

  <AgeGate />
  <Header />

  <main class="bg-grain min-h-svh pb-24">
    <!-- Bannière hero : grande image d'ambiance, titre en surimpression -->
    {
      media.hero ? (
        <section class="relative flex min-h-[52svh] items-end overflow-hidden md:min-h-[62svh]">
          <Image
            src={media.hero.src}
            alt={media.hero.alt}
            width={1600}
            widths={[768, 1200, 1600]}
            sizes="100vw"
            loading="eager"
            fetchpriority="high"
            class:list={['absolute inset-0 h-full w-full object-cover', media.hero.position]}
          />
          <div class="absolute inset-0 bg-gradient-to-t from-noir via-noir/40 to-noir/30" aria-hidden="true" />

          <div class="relative z-10 mx-auto w-full max-w-6xl px-5 pt-40 pb-10 md:px-8">
            <nav aria-label="Fil d'Ariane" class="text-xs tracking-[0.2em] text-creme/60 uppercase">
              <a href="/" class="transition-colors hover:text-or">Accueil</a>
              <span class="mx-2" aria-hidden="true">/</span>
              <a href="/rhums/" class="transition-colors hover:text-or">Nos rhums</a>
            </nav>
            <p class="mt-6 mb-3 text-xs tracking-[0.35em] text-or-light uppercase">{product.category}</p>
            <h1
              class="font-display max-w-3xl text-balance text-3xl font-semibold tracking-wide text-creme md:text-5xl"
              data-split
            >
              {product.name}
            </h1>
            <div class="mt-5 flex flex-wrap items-center gap-3">
              {product.signature && (
                <p class="inline-block bg-or px-4 py-1 text-[0.65rem] font-medium tracking-[0.2em] text-noir uppercase">
                  Unique au monde
                </p>
              )}
              {product.disponible === false && (
                <p class="inline-block border border-or/60 bg-noir/60 px-4 py-1 text-[0.65rem] tracking-[0.2em] text-or-light uppercase">
                  Bientôt disponible
                </p>
              )}
            </div>
          </div>
        </section>
      ) : (
        <header class="mx-auto max-w-6xl px-5 pt-28 md:px-8 md:pt-36">
          <nav aria-label="Fil d'Ariane" class="text-xs tracking-[0.2em] text-creme/50 uppercase">
            <a href="/" class="transition-colors hover:text-or">Accueil</a>
            <span class="mx-2" aria-hidden="true">/</span>
            <a href="/rhums/" class="transition-colors hover:text-or">Nos rhums</a>
          </nav>
          <p class="mt-10 mb-4 text-xs tracking-[0.35em] text-or uppercase">{product.category}</p>
          <h1
            class="font-display max-w-3xl text-balance text-3xl font-semibold tracking-wide text-creme md:text-5xl"
            data-split
          >
            {product.name}
          </h1>
          {product.disponible === false && (
            <p class="mt-5 inline-block border border-or/40 px-4 py-1 text-[0.65rem] tracking-[0.2em] text-or-light uppercase">
              Bientôt disponible
            </p>
          )}
        </header>
      )
    }

    <article class="mx-auto max-w-6xl px-5 md:px-8">
      <!-- Texte à gauche, fiche technique en regard à droite : plus de vide -->
      <div class="mt-14 grid items-start gap-12 lg:grid-cols-5 lg:gap-16">
        <div class="lg:col-span-3">
          <div class="space-y-5 leading-relaxed text-creme-muted" data-reveal-group>
            {(product.longText ?? [product.description]).map((paragraphe) => <p>{paragraphe}</p>)}
          </div>

          {
            product.notes && (
              <blockquote class="mt-8 border-l-2 border-or pl-6" data-reveal>
                <p class="font-script text-2xl text-or-light">{product.notes}</p>
              </blockquote>
            )
          }

          <div class="mt-12 flex flex-wrap gap-4" data-reveal>
            <a
              href="/#contact"
              class="group inline-flex items-center gap-3 border border-or bg-or/10 px-8 py-3.5 text-sm tracking-[0.2em] text-or uppercase transition-all duration-500 hover:bg-or hover:text-noir"
            >
              Nous contacter
              <span class="transition-transform duration-500 group-hover:translate-x-1" aria-hidden="true">→</span>
            </a>
            <a
              href="/rhums/"
              class="inline-flex items-center px-6 py-3.5 text-sm tracking-[0.2em] text-creme/70 uppercase transition-colors duration-500 hover:text-or"
            >
              ← Tous nos rhums
            </a>
          </div>
        </div>

        {
          product.facts && (
            <aside class="border border-or/20 bg-noir-800/60 p-7 lg:col-span-2" data-reveal>
              <h2 class="font-display text-lg tracking-widest text-or uppercase">Fiche technique</h2>
              <dl class="mt-6 divide-y divide-or/10">
                {Object.entries(product.facts).map(([cle, valeur]) => (
                  <div class="py-3 text-sm">
                    <dt class="tracking-widest text-creme/60 uppercase">{cle}</dt>
                    <dd class="mt-1 text-creme">{valeur}</dd>
                  </div>
                ))}
              </dl>
            </aside>
          )
        }
      </div>

      <!-- Galerie horizontale sous le contenu : photos puis vidéos -->
      {
        (media.galerie.length > 0 || media.videos.length > 0) && (
          <div class="mt-20 grid gap-8 sm:grid-cols-2 lg:grid-cols-4" data-reveal-group>
            {media.galerie.map((photo) => (
              <figure data-mask-reveal>
                <Image
                  src={photo.src}
                  alt={photo.alt}
                  width={760}
                  widths={[420, 760]}
                  sizes="(min-width: 1024px) 23vw, (min-width: 640px) 46vw, 92vw"
                  loading="lazy"
                  class="aspect-[4/5] w-full border border-or/20 object-cover"
                />
              </figure>
            ))}
            {media.videos.map((video) => (
              <figure>
                <video
                  src={video.src}
                  poster={video.poster}
                  muted
                  loop
                  playsinline
                  autoplay
                  preload="none"
                  class="aspect-[4/5] w-full border border-or/20 object-cover"
                  aria-label={video.aria}
                />
                <figcaption class="mt-3 text-center text-xs tracking-[0.2em] text-creme/50 uppercase">
                  {video.caption}
                </figcaption>
              </figure>
            ))}
          </div>
        )
      }

      {
        product.slug === 'rhums-arranges' && (
          <p class="mt-16 border border-dashed border-or/25 p-6 text-sm text-creme/50" data-reveal>
            Photos des rhums arrangés à venir — letchi, passion, banane et épices sont en macération.
          </p>
        )
      }
    </article>
  </main>

  <Footer />

  <script>
    import '@/scripts/essentials.ts';
    const loadAnimations = () => import('@/scripts/animations.ts');
    if ('requestIdleCallback' in window) {
      requestIdleCallback(() => loadAnimations(), { timeout: 1500 });
    } else {
      setTimeout(loadAnimations, 250);
    }
  </script>
</BaseLayout>
