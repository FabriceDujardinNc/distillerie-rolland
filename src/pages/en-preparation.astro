---
/**
 * Page teaser de pré-lancement. Servie à la place du site par le .htaccess
 * tant que le visiteur n'a pas le code d'accès (?acces=…) — voir README.
 * noindex : Google ne doit pas indexer ce placeholder comme page d'accueil.
 */
import { Image } from 'astro:assets';
import BaseLayout from '@/layouts/BaseLayout.astro';
import monogrammeOr from '@/assets/images/logo-distillerie-rolland-monogramme-or.png';
import { site } from '@/data/site';
---

<BaseLayout
  title="Distillerie Rolland — Site en préparation"
  description="Le site de la Distillerie Rolland, distillerie artisanale en Nouvelle-Calédonie, ouvre bientôt ses portes."
  path="/en-preparation"
  noindex
>
  <!-- Centrage par marges auto (m-auto) et non par justify-center : si le
       contenu dépasse la hauteur de l'écran, la page scrolle au lieu de
       rogner le haut -->
  <main class="bg-grain relative flex min-h-svh flex-col overflow-x-hidden px-5 py-10 text-center">
    <div
      class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_center,transparent_30%,rgb(12_10_8/0.9)_100%)]"
      aria-hidden="true"
    >
    </div>

    <div class="relative z-10 m-auto flex max-w-2xl flex-col items-center">
      <Image
        src={monogrammeOr}
        alt=""
        width={380}
        densities={[1, 2]}
        loading="eager"
        fetchpriority="high"
        class="w-48 opacity-90 md:w-60"
      />

      <h1
        class="font-display mt-8 text-4xl font-semibold tracking-[0.1em] text-or uppercase md:text-6xl"
      >
        Distillerie<br />Rolland
      </h1>

      <div class="gold-rule my-8 w-full max-w-xs">
        <span class="text-or" aria-hidden="true">◆</span>
      </div>

      <p class="text-sm tracking-[0.35em] text-creme uppercase md:text-base">
        Site en préparation
      </p>

      <p class="mt-6 max-w-md leading-relaxed text-creme-muted">
        Nos alambics chauffent, nos rhums s'affinent. Le site de la Distillerie Rolland —
        {site.address.locality}, {site.address.country} — ouvre bientôt ses portes.
      </p>

      <!-- Compte à rebours (piloté par src/scripts/countdown.ts).
           Sans JS, la date reste affichée en toutes lettres. -->
      <p class="mt-8 text-xs tracking-[0.35em] text-or uppercase">
        Ouverture le {
          new Date(site.launchDate).toLocaleDateString('fr-FR', {
            day: 'numeric',
            month: 'long',
            year: 'numeric',
            timeZone: 'Pacific/Noumea',
          })
        }
      </p>
      <div
        id="countdown"
        data-launch={site.launchDate}
        class="mt-5 grid w-full max-w-md grid-cols-2 gap-3 opacity-0 transition-opacity duration-700 sm:max-w-none sm:grid-cols-4 sm:gap-5"
      >
        {
          ['jours', 'heures', 'minutes', 'secondes'].map((unit) => (
            <div class="overflow-hidden border border-or/25 bg-noir-800/60 px-2 py-4 sm:min-w-20 sm:px-5">
              <p
                data-unit={unit}
                class="font-display text-2xl text-or tabular-nums sm:text-4xl"
              >
                0
              </p>
              <p class="mt-2 text-[0.6rem] tracking-[0.15em] text-creme/50 uppercase">{unit}</p>
            </div>
          ))
        }
      </div>

      <p class="font-script mt-8 text-2xl text-or-light md:text-3xl">{site.motto}</p>

      <a
        href={`mailto:${site.email}`}
        class="mt-10 inline-block border border-or/50 px-8 py-3 text-xs tracking-[0.25em] text-or uppercase transition-all duration-500 hover:bg-or hover:text-noir"
      >
        {site.email}
      </a>

      <p class="mt-12 text-[0.65rem] tracking-widest text-creme/40 uppercase">
        L'abus d'alcool est dangereux pour la santé. À consommer avec modération.
      </p>
    </div>
  </main>

  <script>
    import '@/scripts/countdown.ts';
  </script>
</BaseLayout>
