---
/**
 * Page d'accueil one-page : hero, distillerie, gaïac, créations, contact.
 * Le JSON-LD LocalBusiness (+ catalogue produits) est injecté ici — c'est
 * la page d'entité principale pour le SEO local Nouvelle-Calédonie.
 */
import { Image } from 'astro:assets';
import BaseLayout from '@/layouts/BaseLayout.astro';
import AgeGate from '@/components/AgeGate.astro';
import Header from '@/components/Header.astro';
import monogrammeOr from '@/assets/images/logo-distillerie-rolland-monogramme-or.png';
import Hero from '@/components/Hero.astro';
import About from '@/components/About.astro';
import Gaiac from '@/components/Gaiac.astro';
import Products from '@/components/Products.astro';
import Marquee from '@/components/Marquee.astro';
import Contact from '@/components/Contact.astro';
import Footer from '@/components/Footer.astro';
import { site } from '@/data/site';

const title =
  'Distillerie Rolland — Rhum artisanal au cœur de gaïac | Moindou, Nouvelle-Calédonie';
const description =
  'Distillerie artisanale à Moindou, à 1 h 30 de Nouméa (Nouvelle-Calédonie) : rhum blanc traditionnel La Métisse, rhum brun au cœur de gaïac torréfié unique au monde, rhums arrangés.';

// Profils sociaux (sameAs) : uniquement ceux renseignés dans site.ts
const sameAs = Object.values(site.social).filter(Boolean);

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'LocalBusiness',
      '@id': `${site.domain}/#distillerie`,
      ...(sameAs.length > 0 && { sameAs }),
      name: site.name,
      description: site.description,
      slogan: site.tagline,
      url: `${site.domain}/`,
      ...(site.phoneHref && { telephone: site.phoneHref }),
      email: site.email,
      image: `${site.domain}/images/og-distillerie-rolland.jpg`,
      priceRange: '$$',
      foundingDate: String(site.foundingYear),
      founder: {
        '@type': 'Person',
        name: site.founder,
        jobTitle: 'Maître distillateur',
      },
      // Adresse volontairement limitée à la commune (pas de rue ni de GPS) :
      // choix de discrétion du client, aligné avec la fiche Google en mode
      // « zone desservie »
      address: {
        '@type': 'PostalAddress',
        addressLocality: site.address.locality,
        postalCode: site.address.postalCode,
        addressRegion: site.address.region,
        addressCountry: site.address.countryCode,
      },
      areaServed: ['Moindou', 'Nouméa', 'Nouvelle-Calédonie'],
      // Pas de catalogue Product ici : sans prix (choix loi Évin) ni avis,
      // les entités Product ne sont pas éligibles aux extraits enrichis et
      // génèrent des erreurs Search Console. Les pages /rhums/… portent le
      // balisage produit détaillé.
    },
    {
      '@type': 'WebSite',
      '@id': `${site.domain}/#website`,
      url: `${site.domain}/`,
      name: site.name,
      inLanguage: 'fr-FR',
      publisher: { '@id': `${site.domain}/#distillerie` },
    },
  ],
};
---

<BaseLayout title={title} description={description} path="/">
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(jsonLd)}
    slot="head"
  />

  <AgeGate />
  <Header />

  <!-- Le sigle de la maison, flottant dans la marge gauche : en grand format
       sur le hero, il reprend sa taille normale en le quittant puis descend
       en parallax jusqu'au footer (grands écrans — piloté par animations.ts) -->
  <Image
    src={monogrammeOr}
    alt=""
    aria-hidden="true"
    id="logo-flottant"
    width={440}
    densities={[1, 2]}
    loading="eager"
    class="pointer-events-none fixed top-[11vh] left-4 z-40 hidden w-[clamp(6.5rem,calc((100vw-76rem)/2),17rem)] opacity-95 drop-shadow-[0_2px_16px_rgb(12_10_8/0.85)] xl:block 2xl:left-8"
  />

  <main>
    <Hero />
    <About />
    <Gaiac />
    <Products />
    <Marquee />
    <Contact />
  </main>

  <Footer />

  <script>
    // Immédiat : interactions essentielles (menu, header) et formulaire — légers
    import '@/scripts/essentials.ts';
    import '@/scripts/contact.ts';

    // Différé : GSAP + animations, importés après le premier rendu pour ne pas
    // bloquer le chargement initial (gros gain Lighthouse mobile). Le contenu
    // est visible sans elles ; elles prennent le relais dès que le navigateur
    // souffle.
    const loadAnimations = () => import('@/scripts/animations.ts');
    if ('requestIdleCallback' in window) {
      requestIdleCallback(() => loadAnimations(), { timeout: 1500 });
    } else {
      setTimeout(loadAnimations, 250);
    }
  </script>
</BaseLayout>
