---
/**
 * Footer : rappel de marque, navigation, mentions légales et
 * avertissement loi Évin (obligatoire pour un site d'alcool).
 */
import { site } from '@/data/site';

const year = new Date().getFullYear();

// Les icônes sociales n'apparaissent que lorsque les URL sont renseignées
// dans site.ts — jamais de lien mort en attendant
const socials = [
  {
    name: 'Facebook',
    url: site.social.facebook,
    // Pictogramme Facebook (tracé officiel simplifié)
    path: 'M13.5 9H15V6.5h-1.5c-1.933 0-3.5 1.567-3.5 3.5v1.5H8V14h2v8h2.5v-8H15l.5-2.5h-3V10a1 1 0 0 1 1-1Z',
  },
  {
    name: 'Instagram',
    url: site.social.instagram,
    // Pictogramme Instagram (appareil photo stylisé)
    path: 'M12 8.5A3.5 3.5 0 1 0 12 15.5 3.5 3.5 0 0 0 12 8.5Zm0 5.75a2.25 2.25 0 1 1 0-4.5 2.25 2.25 0 0 1 0 4.5ZM16.25 6.5a1 1 0 1 0 0 2 1 1 0 0 0 0-2ZM8 5h8a3 3 0 0 1 3 3v8a3 3 0 0 1-3 3H8a3 3 0 0 1-3-3V8a3 3 0 0 1 3-3Zm8 1.5H8A1.5 1.5 0 0 0 6.5 8v8A1.5 1.5 0 0 0 8 17.5h8a1.5 1.5 0 0 0 1.5-1.5V8A1.5 1.5 0 0 0 16 6.5Z',
  },
  {
    name: 'LinkedIn',
    url: site.social.linkedin,
    // Pictogramme LinkedIn (in)
    path: 'M6.5 8.75A1.75 1.75 0 1 0 6.5 5.25a1.75 1.75 0 0 0 0 3.5ZM5.25 10h2.5v8.5h-2.5V10Zm4.75 0h2.4v1.16h.03c.33-.6 1.15-1.28 2.37-1.28 2.53 0 3 1.6 3 3.68v4.94h-2.5v-4.38c0-1.05-.02-2.4-1.5-2.4-1.5 0-1.73 1.14-1.73 2.32v4.46H10V10Z',
  },
].filter((s) => s.url);
---

<footer class="relative z-30 border-t border-or/15 bg-noir">
  <div class="mx-auto max-w-6xl px-5 py-14 md:px-8">
    <div class="flex flex-col items-center gap-10 md:flex-row md:items-start md:justify-between">
      <div class="text-center md:text-left">
        <p class="font-display text-lg tracking-[0.25em] text-or">DISTILLERIE ROLLAND</p>
        <p class="font-script mt-2 text-xl text-or-light/80">{site.motto}</p>
        <p class="mt-4 text-sm leading-relaxed text-creme/50">
          {site.address.locality}, {site.address.country}
        </p>

        {
          socials.length > 0 && (
            <ul class="mt-5 flex justify-center gap-4 md:justify-start">
              {socials.map((s) => (
                <li>
                  <a
                    href={s.url}
                    target="_blank"
                    rel="noopener"
                    aria-label={`${site.name} sur ${s.name}`}
                    class="flex h-10 w-10 items-center justify-center rounded-full border border-or/30 text-or transition-colors duration-300 hover:border-or hover:bg-or hover:text-noir"
                  >
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                      <path d={s.path} />
                    </svg>
                  </a>
                </li>
              ))}
            </ul>
          )
        }
      </div>

      <nav aria-label="Navigation de bas de page">
        <ul class="flex flex-col items-center gap-3 text-sm md:items-end">
          <li>
            <a href="/#distillerie" class="text-creme/60 transition-colors hover:text-or"
              >La distillerie</a
            >
          </li>
          <li>
            <a href="/#gaiac" class="text-creme/60 transition-colors hover:text-or">Le gaïac</a>
          </li>
          <li>
            <a href="/#creations" class="text-creme/60 transition-colors hover:text-or"
              >Nos créations</a
            >
          </li>
          <li>
            <a href="/#contact" class="text-creme/60 transition-colors hover:text-or">Contact</a>
          </li>
        </ul>
      </nav>
    </div>

    <div class="mt-12 border-t border-or/10 pt-8 text-center">
      <p class="text-xs font-medium tracking-[0.15em] text-creme/70 uppercase">
        L'abus d'alcool est dangereux pour la santé. À consommer avec modération.
      </p>
      <p class="mt-2 text-xs text-creme/65">
        La vente d'alcool est interdite aux mineurs.
      </p>

      <!-- Bloc légal -->
      <ul
        class="mt-8 flex flex-col items-center gap-2 text-xs text-creme/65 sm:flex-row sm:justify-center sm:gap-6"
      >
        <li>© {year} {site.name}</li>
        <li>
          <a href="/mentions-legales/" class="transition-colors hover:text-or">
            Mentions légales
          </a>
        </li>
        <li>
          <a href="/politique-de-confidentialite/" class="transition-colors hover:text-or">
            Politique de confidentialité
          </a>
        </li>
      </ul>
    </div>
  </div>
</footer>
