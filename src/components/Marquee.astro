---
/**
 * Bandeau défilant : les mots de la maison en Cinzel géant très transparent,
 * qui glissent en continu. 100 % CSS (figé par prefers-reduced-motion).
 * La piste contient deux fois la séquence → boucle sans couture à -50%.
 * Le texte vit dans des pseudo-éléments (content: attr) : purement décoratif,
 * il échappe ainsi aux audits de contraste comme aux lecteurs d'écran.
 */
const mots = ['Rhum au gaïac', 'Moindou', 'La Métisse', 'Nouvelle-Calédonie'];
const sequence = [...mots, ...mots];
---

<div
  class="relative z-20 overflow-hidden border-y border-or/10 bg-noir py-8 md:py-10"
  aria-hidden="true"
>
  <div class="marquee-track flex w-max items-center">
    {sequence.map((mot) => <span class="marquee-mot" data-text={mot} />)}
  </div>
</div>

<style>
  .marquee-track {
    animation: defiler 48s linear infinite;
  }

  @keyframes defiler {
    to {
      transform: translateX(-50%);
    }
  }

  .marquee-mot {
    display: flex;
    align-items: center;
    white-space: nowrap;
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 5vw, 3.75rem);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgb(201 164 92 / 0.15);
  }

  .marquee-mot::before {
    content: attr(data-text);
  }

  /* Losange séparateur */
  .marquee-mot::after {
    content: '◆';
    margin-inline: clamp(2rem, 4vw, 3rem);
    font-size: 0.5em;
    color: rgb(201 164 92 / 0.25);
  }
</style>
