---
/**
 * Layout racine : toute la stratégie SEO / performance est centralisée ici.
 * - Meta complètes (title, description, canonical, Open Graph, Twitter Cards)
 * - Polices auto-hébergées (@fontsource) + preload de la police de titre (LCP)
 * - JSON-LD injectable par page via le slot "head"
 */
import '@fontsource/cinzel/400.css';
import '@fontsource/cinzel/600.css';
import '@fontsource-variable/jost';
import '@fontsource/great-vibes';
import '@/styles/global.css';
import cinzel600Url from '@fontsource/cinzel/files/cinzel-latin-600-normal.woff2?url';
import { site } from '@/data/site';

interface Props {
  title: string;
  description: string;
  /** Chemin canonique de la page, ex. "/" ou "/mentions-legales" */
  path?: string;
  /** Image Open Graph absolue ou relative à la racine */
  ogImage?: string;
  noindex?: boolean;
}

const {
  title,
  description,
  path = '/',
  ogImage = '/images/og-distillerie-rolland.jpg',
  noindex = false,
} = Astro.props;

const canonical = new URL(path, site.domain).href;
const ogImageUrl = new URL(ogImage, site.domain).href;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${site.name} — ${site.tagline}`} />

    <!-- Twitter Cards -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Favicons — jeu généré via RealFaviconGenerator -->
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="DR" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#0c0a08" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Preload de la police des titres : le H1 du hero est le LCP -->
    <link rel="preload" as="font" type="font/woff2" href={cinzel600Url} crossorigin />

    <slot name="head" />
  </head>
  <body class="bg-noir text-creme antialiased">
    <slot />
  </body>
</html>
