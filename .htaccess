# ==========================================================================
# Distillerie Rolland — configuration Apache/LiteSpeed (Hostinger)
# Ce fichier est copié tel quel dans dist/ lors du build Astro.
# ==========================================================================

Options -Indexes
ServerSignature Off

# Le déploiement se fait par git pull dans public_html : le dépôt ne doit
# jamais être servi
RedirectMatch 404 /\.git

# --------------------------------------------------------------------------
# 1) HTTPS + domaine canonique (www)
# --------------------------------------------------------------------------
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Force HTTPS
  RewriteCond %{HTTPS} !=on
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

  # Force www (canonique : https://www.distillerie-rolland.com)
  RewriteCond %{HTTP_HOST} ^distillerie-rolland\.com$ [NC]
  RewriteRule ^ https://www.distillerie-rolland.com%{REQUEST_URI} [R=301,L]

</IfModule>

<IfModule mod_headers.c>
  # --------------------------------------------------------------------------
  # 3) Sécurité
  # --------------------------------------------------------------------------
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"
  # script/frame/connect hcaptcha + web3forms : requis par le widget anti-bot du formulaire
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' https://web3forms.com https://hcaptcha.com https://*.hcaptcha.com; style-src 'self' 'unsafe-inline' https://hcaptcha.com https://*.hcaptcha.com; img-src 'self' data:; font-src 'self'; connect-src 'self' https://api.web3forms.com https://hcaptcha.com https://*.hcaptcha.com; frame-src https://hcaptcha.com https://*.hcaptcha.com; form-action 'self' https://api.web3forms.com; object-src 'none'; base-uri 'self'; frame-ancestors 'self'; upgrade-insecure-requests"

  # --------------------------------------------------------------------------
  # 4) Cache navigateur
  # --------------------------------------------------------------------------
  # Assets Astro : noms hashés → cache agressif immutable
  <FilesMatch "^.+\.(js|mjs|css|woff2?)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # Images : un mois
  <FilesMatch "\.(jpg|jpeg|png|webp|avif|svg|gif|ico)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>
  # HTML : toujours revalidé (le contenu peut changer à chaque déploiement)
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>

# --------------------------------------------------------------------------
# 5) Compression
# --------------------------------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/plain text/xml
  AddOutputFilterByType DEFLATE application/javascript application/json
  AddOutputFilterByType DEFLATE image/svg+xml application/xml
</IfModule>

# --------------------------------------------------------------------------
# 6) Types MIME modernes
# --------------------------------------------------------------------------
<IfModule mod_mime.c>
  AddType image/avif .avif
  AddType image/webp .webp
  AddType font/woff2 .woff2
</IfModule>

# Page 404 personnalisée « La part des anges »
ErrorDocument 404 /404.html
